# Cópialo a .env y completa con los valores de tu VPS + SingleStore Cloud.
# infra/configure.sh lee este archivo y lo aplica a los nginx vhosts y compose files.

# ---------------------------------------------------------------------------
# Dominio raíz de tu VPS (los 3 subdominios se construyen sobre este)
# Ej. si VPS_DOMAIN=mivps.duckdns.org, los servicios quedan en:
#   ollama-api.mivps.duckdns.org
#   examen-api.mivps.duckdns.org
#   examen-ui.mivps.duckdns.org
# Requiere certificado wildcard *.mivps.duckdns.org en /etc/letsencrypt/.
# ---------------------------------------------------------------------------
VPS_DOMAIN=tu-vps.example.com
VPS_HOST=tu-vps.example.com
VPS_USER=root

# ---------------------------------------------------------------------------
# API key compartida — la inyecta el nginx server-side.
# Genérala con: openssl rand -hex 32
# ---------------------------------------------------------------------------
API_KEY=reemplazar-con-openssl-rand-hex-32

# ---------------------------------------------------------------------------
# Password compartido para Mongo y MinIO (mismo valor en el setup default).
# Mongo solo aloja jobs + config; papers se almacenan en SingleStore.
# ---------------------------------------------------------------------------
DB_PASSWORD=reemplazar-con-password-seguro

# ---------------------------------------------------------------------------
# SingleStore Cloud (storage de papers con embeddings VECTOR(384))
# Crear workspace gratis en https://portal.singlestore.com/
# Formato: mysql://user:pass@svc-xxx.svc.singlestore.com:3306/db_name
# El password de SingleStore es DISTINTO de DB_PASSWORD (workspace tiene su propio user).
# Antes del primer uso ejecutar infra/singlestore/schema.sql en el portal.
# ---------------------------------------------------------------------------
SINGLESTORE_URL=mysql://admin:reemplazar-con-password-singlestore@svc-xxx.svc.singlestore.com:3306/examen_papers

# ---------------------------------------------------------------------------
# Modelo Ollama a precargar
# ---------------------------------------------------------------------------
OLLAMA_DEFAULT_MODEL=qwen2.5:1.5b
